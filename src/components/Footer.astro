---
// src/components/Footer.astro
---
<footer id="contact" class="relative bg-[#02275A] text-white pt-16 pb-10 overflow-hidden">
  <div class="pointer-events-none absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-[#93C5FD]/40 to-transparent"></div>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-10 md:gap-12 pb-10 mb-8 border-b border-white/10">
      <div>
        <h4 class="text-xs uppercase font-bold tracking-[0.25em] text-[#93C5FD] mb-5">Connect With Us</h4>
        <p class="text-xl font-bold font-display text-white mb-1">Alisha Beverley</p>
        <p class="text-white/60 text-base mb-4">Director</p>
        <a onclick="event.preventDefault();location.href='mailto:alisha.beverley@hamptonu.edu'" href="mailto:alisha.beverley@hamptonu.edu" class="inline-flex items-center gap-2 text-white hover:text-[#93C5FD] underline decoration-white/30 underline-offset-2 transition-colors text-base font-medium">
          <svg class="h-5 w-5 shrink-0 text-[#93C5FD]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 0 1-2.25 2.25h-15a2.25 2.25 0 0 1-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25m19.5 0v.243a2.25 2.25 0 0 1-1.07 1.916l-7.5 4.615a2.25 2.25 0 0 1-2.36 0L3.32 8.91a2.25 2.25 0 0 1-1.07-1.916V6.75" /></svg>
          alisha.beverley@hamptonu.edu
        </a>
        <a onclick="event.preventDefault();location.href='tel:7577275434'" href="tel:7577275434" class="flex items-center gap-2 text-white/70 hover:text-white underline decoration-white/30 underline-offset-2 transition-colors text-base font-medium mt-2">
          <svg class="h-5 w-5 shrink-0 text-[#93C5FD]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 0 0 2.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 0 1-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 0 0-1.091-.852H4.5A2.25 2.25 0 0 0 2.25 4.5v2.25Z" /></svg>
          (757) 727-5434
        </a>
        <a onclick="event.preventDefault();location.href='tel:7577275579'" href="tel:7577275579" class="flex items-center gap-2 text-white/70 hover:text-white underline decoration-white/30 underline-offset-2 transition-colors text-base font-medium mt-1.5">
          <svg class="h-5 w-5 shrink-0 invisible" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 0 0 2.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 0 1-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 0 0-1.091-.852H4.5A2.25 2.25 0 0 0 2.25 4.5v2.25Z" /></svg>
          (757) 727-5579
        </a>
        <a href="https://www.facebook.com/OlliatHU/" target="_blank" rel="noopener noreferrer" class="flex items-center gap-2 text-white/70 hover:text-white underline decoration-white/30 underline-offset-2 transition-colors text-base font-medium mt-2">
          <svg class="h-5 w-5 shrink-0 text-[#93C5FD]" fill="currentColor" viewBox="0 0 24 24"><path d="M22 12c0-5.523-4.477-10-10-10S2 6.477 2 12c0 4.991 3.657 9.128 8.438 9.878v-6.987h-2.54V12h2.54V9.797c0-2.506 1.492-3.89 3.777-3.89 1.094 0 2.238.195 2.238.195v2.46h-1.26c-1.243 0-1.63.771-1.63 1.562V12h2.773l-.443 2.89h-2.33v6.988C18.343 21.128 22 16.991 22 12Z"/></svg>
          Follow us on Facebook
        </a>
        <p class="text-sm text-white/50 mt-6 leading-relaxed pt-5 border-t border-white/10">
          Monday–Friday: 8:30am–5pm<br/>
          Closed for University holidays
        </p>
      </div>

      <div>
        <h4 class="text-xs uppercase font-bold tracking-[0.25em] text-[#93C5FD] mb-5">Address</h4>
        <p class="text-white/80 leading-relaxed text-base mb-5">
          <span class="block font-semibold text-white text-sm uppercase tracking-[0.1em] mb-1">Physical</span>
          1006-H Settlers Landing Road<br/>
          Hampton, Virginia 23669
        </p>
        <p class="text-white/80 leading-relaxed text-base">
          <span class="block font-semibold text-white text-sm uppercase tracking-[0.1em] mb-1">Mailing</span>
          Hampton University<br/>
          Osher Lifelong Learning Institute<br/>
          P.O. Box 6162<br/>
          Hampton, VA 23668
        </p>
      </div>

      <div>
        <h4 class="text-xs uppercase font-bold tracking-[0.25em] text-[#93C5FD] mb-5">Quick Links</h4>
        <div class="flex flex-col space-y-3 text-base">
          <a href="https://www.hamptonu.edu/" target="_blank" rel="noreferrer" class="text-white/70 hover:text-white transition-colors hover:underline decoration-white/30 underline-offset-2">Hampton University</a>
          <a href="https://form.jotform.com/213249037988164" target="_blank" rel="noreferrer" class="text-white/70 hover:text-white transition-colors hover:underline decoration-white/30 underline-offset-2">Membership Registration</a>
          <a href="https://form.jotform.com/230106409375148" target="_blank" rel="noreferrer" class="text-white/70 hover:text-white transition-colors hover:underline decoration-white/30 underline-offset-2">Course Registration</a>
          <a href="https://www.osherfoundation.org/" target="_blank" rel="noreferrer" class="text-white/70 hover:text-white transition-colors hover:underline decoration-white/30 underline-offset-2">Osher Foundation</a>
        </div>
      </div>
    </div>

    <div class="flex flex-col sm:flex-row justify-between items-center gap-3 text-sm text-white/40">
      <p>&copy; {new Date().getFullYear()} Hampton University Osher Lifelong Learning Institute. All rights reserved.</p>
      <p class="text-white/30 text-xs tracking-[0.15em] uppercase">home.hamptonu.edu/osher</p>
    </div>
  </div>
</footer>