---
import Layout from '../layouts/Layout.astro';
---

<Layout>
  <div class="max-w-4xl mx-auto px-4 py-16">
    <h1 class="text-4xl font-extrabold text-[#02275A] mb-6">Volunteer with OLLI</h1>
    <p class="text-lg text-[#353A3C] mb-10">
      We are always looking for enthusiastic members to contribute as Course Instructors, 
      Workshop Facilitators, and Interest Group Leaders. Please fill out the form below 
      to get started.
    </p>

    <div class="bg-white p-6 rounded-2xl shadow-lg border border-gray-100">
      <script type="text/javascript" src="https://form.jotform.com/jsform/250904273696060"></script>
    </div>
  </div>
</Layout>