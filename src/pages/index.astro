---
import Layout from '../layouts/Layout.astro';
import VolunteerCard from '../components/VolunteerCard.astro';
import OsherLogo from '../images/Osher20Logo.png';
import HeroBG from '../images/HeroBG.png';
import CourseCatalogImg from '../images/CourseCatalog/1.png';
import InterestGroupImg from '../images/CourseCatalog/8.png';
import strip1 from '../images/Strip1.png';
import strip2 from '../images/Strip2.png';
import strip3 from '../images/Strip3.png';
import strip4 from '../images/Strip4.jpg';
import strip5 from '../images/Strip5.jpg';
import strip6 from '../images/Strip6.png';

const catalogImages = Object.entries(
  import.meta.glob('../images/CourseCatalog/*.png', { eager: true, query: '?url', import: 'default' })
)
  .sort(([a], [b]) => {
    const numA = parseInt(a.match(/(\d+)\.png$/)?.[1] || '0');
    const numB = parseInt(b.match(/(\d+)\.png$/)?.[1] || '0');
    return numA - numB;
  })
  .map(([, src]) => src);

const isCover = (i) => i === 0;
const isLastInLeftPair = (i) => i > 0 && i % 2 === 1;
const isFirstInRightPair = (i) => i > 0 && i % 2 === 0;
---

<Layout>
  <!-- ====== Hero ====== -->
  <section class="relative flex min-h-[90vh] items-center overflow-hidden">
    <!-- Background image with blur -->
    <div class="absolute inset-0">
      <img
        src={HeroBG.src}
        alt="OLLI members engaged in a lifelong learning lecture"
        class="h-full w-full object-cover blur-sm scale-110"
      />
      <!-- Stronger overlay for text pop -->
      <div class="absolute inset-0 bg-gradient-to-t from-[#02275A]/90 via-[#02275A]/70 to-[#02275A]/45"></div>
      <!-- Brand glow -->
      <div class="pointer-events-none absolute -top-32 left-1/2 -translate-x-1/2 h-[500px] w-[800px] max-w-full opacity-[0.2]" style="background: radial-gradient(ellipse 50% 50% at center, #004ADD 0%, transparent 70%);"></div>
    </div>

    <div class="relative z-10 mx-auto flex w-full max-w-4xl flex-col items-center px-4 pb-24 pt-32 text-center sm:px-6 lg:px-8">
      <img
        src={OsherLogo.src}
        alt="Osher Lifelong Learning Institute logo"
        class="mx-auto mb-8 h-auto w-full max-w-[130px] brightness-0 invert sm:max-w-[160px] lg:max-w-[200px]"
        style="filter: drop-shadow(0 2px 4px rgba(0,0,0,0.3)) drop-shadow(0 0 2px rgba(255,255,255,0.15)) brightness(0) invert(1);"
      />

      <h1 class="text-5xl font-black font-display leading-tight tracking-[-0.02em] text-white md:text-7xl lg:text-8xl" style="text-shadow: 0 1px 2px rgba(0,0,0,0.4), 0 0 1px rgba(255,255,255,0.1);">
        50+ Living. Learning. Loving It.
      </h1>

      <p class="mt-5 text-lg font-semibold text-blue-200 sm:text-xl">
        Curiosity Never Retires.
      </p>

      <p class="mt-8 max-w-2xl text-base leading-relaxed text-white/80 sm:text-lg">
        The Osher Lifelong Learning Institute (OLLI) at Hampton University is a membership-driven community offering affordable, non-credit courses to mature adult learners. Expand your mind, explore new ideas, and build lasting friendships.
      </p>

      <div class="mt-10 flex flex-col items-center gap-4">
        <button id="open-catalog-btn" class="inline-flex cursor-pointer items-center justify-center rounded-full bg-white px-10 py-4 text-lg font-semibold text-[#02275A] shadow-lg transition hover:bg-blue-50 hover:shadow-xl hover:-translate-y-0.5">
          Explore Course Catalog
        </button>

        <div class="flex flex-wrap items-center justify-center gap-x-6 gap-y-2 text-sm">
          <span class="font-semibold text-white/90">Annual membership is $60/year</span>
          <a href="/faq#membership" class="font-medium text-blue-200 underline decoration-1 underline-offset-2 transition hover:text-white">Learn more →</a>
        </div>

        <p class="text-sm text-white/60">No tests, no grades, no pressure</p>

        <a href="https://form.jotform.com/213249037988164" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-1.5 text-sm font-semibold text-blue-200 transition hover:text-white">
          Ready to join? Become a Member
          <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
        </a>
      </div>
    </div>

    <!-- Curved bottom separator -->
    <div class="absolute bottom-0 left-0 right-0 z-10 h-16">
      <svg class="h-full w-full" viewBox="0 0 1440 64" preserveAspectRatio="none" fill="#F5F8FD">
        <path d="M0 64 Q360 0 720 32 Q1080 64 1440 16 L1440 64 Z" />
      </svg>
    </div>
  </section>

  <!-- ====== Video section ====== -->
  <section class="relative bg-[#F5F8FD] pb-16 pt-8">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
      <div class="relative overflow-hidden rounded-xl shadow-xl shadow-slate-900/10 ring-1 ring-slate-900/5">
        <div class="aspect-[16/9]">
          <iframe
            class="h-full w-full"
            src="https://www.youtube.com/embed/OdqutEB3t3Q?rel=0&autoplay=1&mute=1&controls=0&modestbranding=1&playsinline=1&loop=1&playlist=OdqutEB3t3Q&iv_load_policy=3&fs=0&showinfo=0"
            title="OLLI at Hampton University video overview"
            allow="autoplay; encrypted-media; picture-in-picture"
            allowfullscreen
          ></iframe>
        </div>
      </div>
    </div>
  </section>

  <section class="bg-white py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid gap-10 lg:grid-cols-[1fr_1.3fr] items-center">
        <div>
          <h2 class="text-3xl sm:text-4xl font-extrabold font-display text-[#02275A] leading-tight">
            No tests. No grades.<br />
            <span class="text-[#004ADD]">Just the joy of learning.</span>
          </h2>
          <p class="mt-2 text-base font-semibold text-[#004ADD]">Welcome to your next chapter.</p>
          <p class="mt-6 text-lg text-slate-700 leading-relaxed">
            OLLI's affordable adult education courses cater specifically to lifelong students who want to improve their skills, explore new concepts, and interact with engaging peers right in their community.
          </p>
        </div>
        <div class="grid grid-cols-3 gap-3">
          <img src={strip1.src} alt="" class="rounded-lg object-cover h-32 md:h-40 w-full transition-transform hover:scale-[1.03] hover:shadow-md" loading="lazy" />
          <img src={strip2.src} alt="" class="rounded-lg object-cover h-32 md:h-40 w-full transition-transform hover:scale-[1.03] hover:shadow-md" loading="lazy" />
          <img src={strip3.src} alt="" class="rounded-lg object-cover h-32 md:h-40 w-full transition-transform hover:scale-[1.03] hover:shadow-md" loading="lazy" />
          <img src={strip4.src} alt="" class="rounded-lg object-cover h-32 md:h-40 w-full transition-transform hover:scale-[1.03] hover:shadow-md" loading="lazy" />
          <img src={strip5.src} alt="" class="rounded-lg object-cover h-32 md:h-40 w-full transition-transform hover:scale-[1.03] hover:shadow-md" loading="lazy" />
          <img src={strip6.src} alt="" class="rounded-lg object-cover h-32 md:h-40 w-full transition-transform hover:scale-[1.03] hover:shadow-md" loading="lazy" />
        </div>
      </div>
    </div>
  </section>

  <section id="get-involved" class="bg-[#F8FAFC] py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center max-w-3xl mx-auto mb-16">
        <h2 class="text-3xl sm:text-4xl font-extrabold font-display text-[#02275A]">Get Involved</h2>
        <p class="mt-4 text-lg text-slate-700">Are you passionate about lifelong learning? Join our dynamic ecosystem of volunteers.</p>
      </div>

      <div class="grid gap-8 md:grid-cols-3">
        <VolunteerCard
          title="Course Instructor"
          description="Share your expertise and inspire others. Whether you have professional experience or a unique hobby, our members are eager to learn from you."
        />
        <VolunteerCard
          title="Workshop Facilitator"
          description="Lead hands-on workshops. Perfect for creative activities, technical skills, or wellness practices in an interactive setting."
        />
        <VolunteerCard
          title="Interest Group Leader"
          description="Guide an interest group and bring together members who share identical passions. Organize discussions and community activities."
        />
      </div>
    </div>
  </section>

  <section class="bg-[#F8FAFC] py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid gap-10 md:grid-cols-2 max-w-5xl mx-auto">
        <blockquote class="relative">
          <span class="text-6xl leading-none font-display font-bold text-[#004ADD]/20 select-none" aria-hidden="true">"</span>
          <p class="relative -mt-4 text-xl md:text-2xl leading-snug font-display font-semibold text-[#02275A]">
            OLLI has given me a community of curious minds and lifelong friends I never expected to find at this stage of life.
          </p>
          <footer class="mt-4 text-sm text-slate-500">
            Margaret — Member since 2022
          </footer>
        </blockquote>
        <blockquote class="relative">
          <span class="text-6xl leading-none font-display font-bold text-[#004ADD]/20 select-none" aria-hidden="true">"</span>
          <p class="relative -mt-4 text-xl md:text-2xl leading-snug font-display font-semibold text-[#02275A]">
            The courses are engaging, affordable, and the instructors are phenomenal. I've taken everything from Spanish to line dancing.
          </p>
          <footer class="mt-4 text-sm text-slate-500">
            Robert — Member since 2021
          </footer>
        </blockquote>
      </div>
    </div>
  </section>

  <section class="bg-white py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid gap-8 md:grid-cols-2">
        <div class="flex flex-col rounded-xl border border-slate-200 bg-white p-6 transition hover:-translate-y-0.5 hover:border-[#004ADD] hover:shadow-md sm:p-8">
          <div class="overflow-hidden rounded-xl mb-6">
            <img
              src={CourseCatalogImg.src}
              alt="Course catalog preview"
              class="h-auto w-full object-contain bg-[#F8FAFC]"
              loading="lazy"
            />
          </div>
          <h3 class="text-2xl font-bold font-display text-[#02275A]">Register for Courses</h3>
          <p class="mt-3 text-base leading-relaxed text-slate-700">
            Explore a diverse selection of engaging courses designed to inspire curiosity, encourage lifelong learning, and connect you with a vibrant community of learners. From wellness and the arts to history, languages, and more, there's something for everyone.
          </p>
          <p class="mt-4 text-base leading-relaxed text-slate-700">
            Browse the course catalog to discover upcoming offerings and find classes that match your interests. When you're ready, register and begin your next learning adventure.
          </p>
          <div class="mt-auto pt-6">
            <a href="https://form.jotform.com/230106409375148" target="_blank" rel="noopener noreferrer" class="inline-flex items-center justify-center rounded-full bg-[#004ADD] px-6 py-3 text-base font-semibold text-white shadow-sm transition hover:bg-[#02275A] hover:shadow-lg hover:-translate-y-0.5">
              Register for Courses
            </a>
          </div>
        </div>

        <div class="flex flex-col rounded-xl border border-slate-200 bg-white p-6 transition hover:-translate-y-0.5 hover:border-[#004ADD] hover:shadow-md sm:p-8">
          <div class="overflow-hidden rounded-xl mb-6">
            <img
              src={InterestGroupImg.src}
              alt="Interest groups preview"
              class="h-auto w-full object-contain bg-[#F8FAFC]"
              loading="lazy"
            />
          </div>
          <h3 class="text-2xl font-bold font-display text-[#02275A]">Register for Interest Groups</h3>
          <p class="mt-3 text-base leading-relaxed text-slate-700">
            Connect with fellow members through shared interests and engaging conversations. OLLI Interest Groups provide opportunities to build friendships, explore hobbies, discuss ideas, and continue learning in a relaxed, community-centered environment.
          </p>
          <p class="mt-4 text-base leading-relaxed text-slate-700">
            Browse the available Interest Groups and register to join a community that shares your passions.
          </p>
          <div class="mt-auto pt-6">
            <a href="https://form.jotform.com/252124261320138" target="_blank" rel="noopener noreferrer" class="inline-flex items-center justify-center rounded-full bg-[#004ADD] px-6 py-3 text-base font-semibold text-white shadow-sm transition hover:bg-[#02275A] hover:shadow-lg hover:-translate-y-0.5">
              Register for Interest Groups
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section id="registration" class="bg-white py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="overflow-hidden rounded-xl bg-gradient-to-br from-[#02275A] to-[#004ADD] p-8 shadow-xl sm:p-14">
        <div class="grid gap-10 lg:grid-cols-[1.8fr_1fr] items-center">
          <div class="text-white">
            <p class="text-sm font-medium text-slate-300">Join OLLI</p>
            <h2 class="mt-4 text-3xl sm:text-4xl font-extrabold font-display">Ready to join our community?</h2>
            <p class="mt-5 text-lg leading-relaxed text-slate-200/90">
              Becoming a member gives you full access to our course catalog, special events, and the chance to connect with hundreds of local learners. Registration is open for the upcoming semester.
            </p>
            <div class="mt-8 flex flex-wrap gap-4">
              <a href="/courses" class="inline-flex items-center justify-center rounded-full bg-white px-8 py-4 text-lg font-semibold text-[#02275A] shadow-lg transition hover:bg-slate-100 hover:shadow-xl hover:-translate-y-0.5">
                View Current Courses
              </a>
              <a href="https://form.jotform.com/213249037988164" target="_blank" rel="noopener noreferrer" class="inline-flex items-center justify-center rounded-full border border-white bg-white/10 px-8 py-4 text-lg font-semibold text-white shadow-sm transition hover:bg-white/20 hover:shadow-lg hover:-translate-y-0.5">
                Become a Member
              </a>
            </div>
          </div>
          <div class="rounded-xl bg-white p-8 shadow-2xl">
            <h3 class="text-xl font-bold font-display text-[#02275A]">Quick Stats</h3>
            <ul class="mt-6 space-y-4 text-slate-700">
              <li class="flex gap-4 text-base leading-7"><svg class="mt-0.5 h-6 w-6 shrink-0 text-[#004ADD]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6.042A8.967 8.967 0 0 0 6 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 0 1 6 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 0 1 6-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0 0 18 18a8.967 8.967 0 0 0-6 2.292m0-14.25v14.25" /></svg><span>50+ Unique Courses</span></li>
              <li class="flex gap-4 text-base leading-7"><svg class="mt-0.5 h-6 w-6 shrink-0 text-[#004ADD]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19.128a9.38 9.38 0 0 0 2.625.372 9.337 9.337 0 0 0 4.121-.952 4.125 4.125 0 0 0-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 0 1 8.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0 1 11.964-3.07M12 6.375a3.375 3.375 0 1 1-6.75 0 3.375 3.375 0 0 1 6.75 0Zm8.25 2.25a2.625 2.625 0 1 1-5.25 0 2.625 2.625 0 0 1 5.25 0Z" /></svg><span>500+ Active Members</span></li>
              <li class="flex gap-4 text-base leading-7"><svg class="mt-0.5 h-6 w-6 shrink-0 text-[#004ADD]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" /><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1 1 15 0Z" /></svg><span>Hampton University Campus</span></li>
            </ul>
          </div>
        </div>
      </div>
    </div>
  </section>
  <dialog id="catalog-modal" class="fixed inset-0 z-[100] h-full max-h-none w-full max-w-none bg-black/70 p-4 backdrop:bg-black/70 open:flex open:items-center open:justify-center">
    <div class="relative w-full max-w-5xl rounded-2xl bg-white p-2 shadow-2xl sm:p-4">
      <button onclick="document.getElementById('catalog-modal').close()" class="absolute -right-3 -top-3 z-10 flex h-9 w-9 items-center justify-center rounded-full bg-[#02275A] text-white shadow-lg transition hover:bg-[#004ADD]" aria-label="Close catalog">
        <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12" />
        </svg>
      </button>

      <div class="swiper [--swiper-navigation-size:24px]" id="catalog-swiper">
        <div class="swiper-wrapper">
          {catalogImages.map((img, idx) => (
            <div class="swiper-slide !flex items-center justify-center {isCover(idx) ? 'cover-slide' : ''}">
              <div class="flex w-full items-center justify-center {isCover(idx) ? 'max-w-[80%]' : ''}">
                <div class="relative flex-1 {!isCover(idx) && isLastInLeftPair(idx) ? 'pr-1 md:pr-2' : ''} {!isCover(idx) && isFirstInRightPair(idx) ? 'pl-1 md:pl-2' : ''}">
                  {!isCover(idx) && isLastInLeftPair(idx) && <div class="pointer-events-none absolute inset-y-0 right-0 w-3 bg-gradient-to-l from-black/5 to-transparent z-10" />}
                  {!isCover(idx) && isFirstInRightPair(idx) && <div class="pointer-events-none absolute inset-y-0 left-0 w-2 bg-gradient-to-r from-black/5 to-transparent z-10" />}
                  <img
                    src={img}
                    alt={`OLLI Course Catalog page $${idx + 1}`}
                    class="h-auto max-h-[75vh] w-full object-contain drop-shadow-[1px_0_4px_rgba(0,0,0,0.12)]"
                    style="background: linear-gradient(135deg, #fefefe 0%, #f8f6f0 100%);"
                    loading="lazy"
                  />
                </div>
              </div>
            </div>
          ))}
        </div>
        <div class="swiper-pagination !relative !mt-3"></div>
        <div class="swiper-button-prev !text-[#004ADD]"></div>
        <div class="swiper-button-next !text-[#004ADD]"></div>
      </div>
    </div>
  </dialog>

  <style>
    #catalog-swiper {
      perspective: 1600px;
    }
    #catalog-swiper .swiper-slide {
      transition: transform 0.5s cubic-bezier(0.22, 0.61, 0.36, 1), opacity 0.4s ease;
    }
    #catalog-swiper.md\:two-up {
      perspective: 1600px;
    }
    #catalog-swiper.md\:two-up .swiper-slide-prev {
      opacity: 0.4;
      transform: perspective(1600px) rotateY(18deg) scale(0.92);
      transform-origin: right center;
    }
    #catalog-swiper.md\:two-up .swiper-slide-next {
      opacity: 0.4;
      transform: perspective(1600px) rotateY(-18deg) scale(0.92);
      transform-origin: left center;
    }
    #catalog-swiper.md\:two-up .swiper-slide-active {
      opacity: 1;
      transform: perspective(1600px) rotateY(0deg) scale(1);
    }
    #catalog-swiper:not(.md\:two-up) .swiper-slide {
      opacity: 1 !important;
      transform: none !important;
    }
    #catalog-swiper:not(.md\:two-up) .swiper-slide img {
      max-height: 85vh;
    }
    #catalog-swiper.md\:two-up .cover-slide > div {
      max-width: none !important;
    }
  </style>

  <script>
    import Swiper from 'swiper';
    import { Navigation, Pagination, Keyboard } from 'swiper/modules';
    import 'swiper/css';
    import 'swiper/css/navigation';
    import 'swiper/css/pagination';

    let swiperInstance = null;

    document.getElementById('open-catalog-btn')?.addEventListener('click', function () {
      const modal = document.getElementById('catalog-modal');
      modal.showModal();

      if (!swiperInstance) {
        const el = document.getElementById('catalog-swiper');
        if (el) {
          const isDesktop = () => window.innerWidth >= 768;

          swiperInstance = new Swiper(el, {
            modules: [Navigation, Pagination, Keyboard],
            slidesPerView: 1,
            slidesPerGroup: 1,
            spaceBetween: 0,
            navigation: { nextEl: '.swiper-button-next', prevEl: '.swiper-button-prev' },
            pagination: { el: '.swiper-pagination', clickable: true },
            keyboard: { enabled: true },
            grabCursor: true,
            breakpoints: {
              768: {
                slidesPerView: 2,
                slidesPerGroup: 2,
                spaceBetween: 0,
              },
            },
            on: {
              init: function () {
                this.el.classList.toggle('md\\:two-up', isDesktop());
              },
              resize: function () {
                this.el.classList.toggle('md\\:two-up', isDesktop());
              },
            },
          });
        }
      } else {
        swiperInstance.update();
      }
    });
  </script>
</Layout>