---
import Layout from '../layouts/Layout.astro';
import VolunteerCard from '../components/VolunteerCard.astro';
---

<Layout>
  {/* HERO SECTION */}
  <section class="relative bg-[#F3F8FC] py-20 lg:py-28 overflow-hidden">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 grid grid-cols-1 lg:grid-cols-12 gap-12 items-center">
      
      {/* Hero Left Column: Heading and Text */}
      <div class="lg:col-span-7">
        <span class="inline-block px-4 py-1.5 rounded-full bg-white border border-gray-300 text-[#004ADD] font-bold tracking-wider uppercase text-xs mb-6">
          50+ Living. Learning. Loving It.
        </span>
        <h1 class="text-4xl sm:text-5xl lg:text-6xl font-extrabold text-[#02275A] leading-tight mb-6 tracking-tight">
          Curiosity Never Retires.
        </h1>
        <p class="text-xl text-[#353A3C] mb-8 leading-relaxed max-w-2xl">
          The Osher Lifelong Learning Institute (OLLI) at Hampton University is a membership-driven community offering affordable, non-credit courses to mature adult learners. Expand your mind, explore new ideas, and build lasting friendships.
        </p>
        
        {/* Call to Actions with Large Clickable Areas */}
        <div class="flex flex-col sm:flex-row gap-4">
          <a href="#registration" class="px-8 py-4 text-center rounded-xl bg-[#02275A] text-white text-lg font-bold hover:bg-[#004ADD] shadow-lg transition transform active:scale-95">
            Explore Course Catalog
          </a>
          <a href="#get-involved" class="px-8 py-4 text-center rounded-xl bg-white text-[#02275A] border-2 border-[#02275A] text-lg font-bold hover:bg-gray-50 transition">
            Become a Member
          </a>
        </div>
      </div>
      
      {/* Hero Right Column: Imagery */}
      <div class="lg:col-span-5 relative">
        <div class="aspect-[4/3] rounded-2xl overflow-hidden shadow-2xl bg-gray-200 border-4 border-white">
          <img 
            src="https://images.unsplash.com/photo-1577896851231-70ef18881754?q=80&w=1000&auto=format&fit=crop" 
            alt="Mature adults learning and laughing together in a classroom environment" 
            class="object-cover w-full h-full"
          />
        </div>
      </div>
      
    </div>
  </section>

  {/* ABOUT INTRO SECTION */}
  <section id="about" class="py-20 bg-white border-b border-gray-100">
    <div class="max-w-4xl mx-auto px-4 text-center">
      <h2 class="text-3xl sm:text-4xl font-extrabold text-[#02275A] mb-6 tracking-tight">
        Welcome to Your Next Chapter
      </h2>
      <p class="text-lg sm:text-xl text-[#353A3C] leading-relaxed">
        OLLI's affordable adult education courses cater specifically to lifelong students who want to improve their skills, explore new concepts, and interact with engaging peers right in their community. There are no tests, no grades, and no homework—just learning for the pure joy of it.
      </p>
    </div>
  </section>

  {/* VOLUNTEER SECTION */}
  <section id="get-involved" class="py-20 bg-gray-100">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center max-w-3xl mx-auto mb-16">
        <h2 class="text-3xl sm:text-4xl font-extrabold text-[#02275A] mb-4">Get Involved</h2>
        <p class="text-lg text-[#353A3C]">Are you passionate about lifelong learning? Join our dynamic ecosystem of volunteers.</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <VolunteerCard 
          title="Course Instructor" 
          description="Share your expertise and inspire others. Whether you have professional experience or a unique hobby, our members are eager to learn from you."
        />
        <VolunteerCard 
          title="Workshop Facilitator" 
          description="Lead hands-on workshops. Perfect for creative activities, technical skills, or wellness practices in an interactive setting."
        />
        <VolunteerCard 
          title="Interest Group Leader" 
          description="Guide an interest group and bring together members who share identical passions. Organize discussions and community activities."
        />
      </div>
    </div>
  </section>

  {/* REGISTRATION SECTION */}
  <section id="registration" class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="bg-[#02275A] rounded-3xl p-8 md:p-16 flex flex-col md:flex-row items-center justify-between gap-12">
        
        <div class="flex-1 text-white">
          <h2 class="text-3xl sm:text-4xl font-extrabold mb-6">Ready to join our community?</h2>
          <p class="text-lg text-gray-300 mb-8 max-w-xl">
            Becoming a member gives you full access to our course catalog, special events, and the chance to connect with hundreds of local learners. Registration is open for the upcoming semester.
          </p>
          <div class="flex flex-wrap gap-4">
            <a href="#" class="px-8 py-4 bg-[#004ADD] text-white font-bold rounded-xl hover:bg-white hover:text-[#02275A] transition shadow-lg">
              View Current Courses
            </a>
            <a href="#" class="px-8 py-4 bg-transparent border-2 border-white text-white font-bold rounded-xl hover:bg-white hover:text-[#02275A] transition">
              Download Membership Form
            </a>
          </div>
        </div>

        <div class="w-full md:w-auto flex-shrink-0">
          <div class="bg-white p-8 rounded-2xl shadow-xl">
            <h3 class="text-xl font-bold text-[#02275A] mb-4">Quick Stats</h3>
            <ul class="space-y-4">
              <li class="flex items-center text-[#353A3C]">
                <span class="text-2xl mr-4">📚</span> 50+ Unique Courses
              </li>
              <li class="flex items-center text-[#353A3C]">
                <span class="text-2xl mr-4">👥</span> 500+ Active Members
              </li>
              <li class="flex items-center text-[#353A3C]">
                <span class="text-2xl mr-4">📍</span> Hampton University Campus
              </li>
            </ul>
          </div>
        </div>

      </div>
    </div>
  </section>
</Layout>