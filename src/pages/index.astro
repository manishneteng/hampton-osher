---
import Layout from '../layouts/Layout.astro';
import VolunteerCard from '../components/VolunteerCard.astro';
import OsherLogo from '../images/Osher20Logo.png';
---

<Layout>
  <section class="bg-[#F5F8FD] py-12 lg:py-16">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 flex flex-col items-center text-center">
      <div class="max-w-4xl">
        <img
          src={OsherLogo.src}
          alt="Osher Lifelong Learning Institute logo"
          class="mx-auto mb-8 h-auto w-full max-w-[140px] sm:max-w-[180px] lg:max-w-[220px]"
        />
        <h1 class="text-5xl md:text-7xl lg:text-8xl font-black text-[#02275A] leading-tight tracking-[-0.02em]">
          50+ Living. Learning. Loving It.
        </h1>
        <p class="mt-4 text-sm uppercase tracking-[0.3em] font-semibold text-[#004ADD]">
          Curiosity Never Retires.
        </p>
        <p class="mt-8 text-lg text-slate-700 leading-relaxed">
          The Osher Lifelong Learning Institute (OLLI) at Hampton University is a membership-driven community offering affordable, non-credit courses to mature adult learners. Expand your mind, explore new ideas, and build lasting friendships.
        </p>

        <div class="mt-10 flex flex-col items-center gap-4 sm:flex-row sm:justify-center">
          <a href="/courses" class="inline-flex items-center justify-center rounded-lg bg-[#02275A] px-8 py-4 text-lg font-semibold text-white transition hover:bg-[#004ADD]">
            Explore Course Catalog
          </a>
          <a href="https://form.jotform.com/213249037988164" target="_blank" rel="noopener noreferrer" class="inline-flex items-center justify-center rounded-lg border border-[#02275A] bg-white px-8 py-4 text-lg font-semibold text-[#02275A] transition hover:bg-slate-50">
            Become a Member
          </a>
        </div>
      </div>

      <div class="mt-12 w-full max-w-4xl">
        <div class="overflow-hidden rounded-2xl border border-slate-200 shadow-sm">
          <div class="aspect-[16/9] bg-slate-950">
            <iframe
              class="h-full w-full"
              src="https://www.youtube.com/embed/OdqutEB3t3Q?rel=0&autoplay=1&mute=1&controls=0&modestbranding=1&playsinline=1&loop=1&playlist=OdqutEB3t3Q&iv_load_policy=3&fs=0&showinfo=0"
              title="OLLI at Hampton University video overview"
              frameborder="0"
              allow="autoplay; encrypted-media; picture-in-picture"
              allowfullscreen
              loading="lazy"
            ></iframe>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section id="about" class="bg-white py-20">
    <div class="max-w-4xl mx-auto px-4 text-center">
      <h2 class="text-3xl sm:text-4xl font-extrabold text-[#02275A] tracking-tight">
        Welcome to Your Next Chapter
      </h2>
      <p class="mt-6 text-lg text-slate-700 leading-relaxed">
        OLLI's affordable adult education courses cater specifically to lifelong students who want to improve their skills, explore new concepts, and interact with engaging peers right in their community. There are no tests, no grades, and no homework—just learning for the pure joy of it.
      </p>
    </div>
  </section>

  <section id="get-involved" class="bg-[#F8FAFC] py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center max-w-3xl mx-auto mb-16">
        <h2 class="text-3xl sm:text-4xl font-extrabold text-[#02275A]">Get Involved</h2>
        <p class="mt-4 text-lg text-slate-700">Are you passionate about lifelong learning? Join our dynamic ecosystem of volunteers.</p>
      </div>

      <div class="grid gap-8 md:grid-cols-3">
        <VolunteerCard
          title="Course Instructor"
          description="Share your expertise and inspire others. Whether you have professional experience or a unique hobby, our members are eager to learn from you."
        />
        <VolunteerCard
          title="Workshop Facilitator"
          description="Lead hands-on workshops. Perfect for creative activities, technical skills, or wellness practices in an interactive setting."
        />
        <VolunteerCard
          title="Interest Group Leader"
          description="Guide an interest group and bring together members who share identical passions. Organize discussions and community activities."
        />
      </div>
    </div>
  </section>

  <section id="registration" class="bg-white py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="overflow-hidden rounded-[24px] bg-gradient-to-br from-[#02275A] to-[#004ADD] p-8 shadow-[0_26px_70px_rgba(2,45,114,0.14)] sm:p-14">
        <div class="grid gap-10 lg:grid-cols-[1.8fr_1fr] items-center">
          <div class="text-white">
            <p class="text-sm uppercase tracking-[0.35em] text-slate-200">Join OLLI</p>
            <h2 class="mt-4 text-3xl sm:text-4xl font-extrabold">Ready to join our community?</h2>
            <p class="mt-5 text-lg leading-relaxed text-slate-200/90">
              Becoming a member gives you full access to our course catalog, special events, and the chance to connect with hundreds of local learners. Registration is open for the upcoming semester.
            </p>
            <div class="mt-8 flex flex-wrap gap-4">
              <a href="/courses" class="inline-flex items-center justify-center rounded-full bg-white px-8 py-4 text-lg font-semibold text-[#02275A] shadow-lg transition hover:bg-slate-100">
                View Current Courses
              </a>
              <a href="https://form.jotform.com/213249037988164" target="_blank" rel="noopener noreferrer" class="inline-flex items-center justify-center rounded-full border border-white bg-white/10 px-8 py-4 text-lg font-semibold text-white transition hover:bg-white/20">
                Become a Member
              </a>
            </div>
          </div>
          <div class="rounded-2xl bg-white p-8 shadow-2xl">
            <h3 class="text-xl font-bold text-[#02275A]">Quick Stats</h3>
            <ul class="mt-6 space-y-4 text-slate-700">
              <li class="flex gap-4 text-base leading-7"><span class="text-2xl">📚</span>50+ Unique Courses</li>
              <li class="flex gap-4 text-base leading-7"><span class="text-2xl">👥</span>500+ Active Members</li>
              <li class="flex gap-4 text-base leading-7"><span class="text-2xl">📍</span>Hampton University Campus</li>
            </ul>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>