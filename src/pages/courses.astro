---
import Layout from '../layouts/Layout.astro';
import CoursesBG from '../images/CoursesBG.png';

const catalogImages = Object.entries(
  import.meta.glob('../images/CourseCatalog/*.png', { eager: true, query: '?url', import: 'default' })
)
  .sort(([a], [b]) => {
    const numA = parseInt(a.match(/(\d+)\.png$/)?.[1] || '0');
    const numB = parseInt(b.match(/(\d+)\.png$/)?.[1] || '0');
    return numA - numB;
  })
  .map(([, src]) => src);

const isCover = (i) => i === 0;
const isLastInLeftPair = (i) => i > 0 && i % 2 === 1;
const isFirstInRightPair = (i) => i > 0 && i % 2 === 0;
---

<Layout>
  <!-- ====== Hero ====== -->
  <section class="relative flex min-h-[60vh] items-center overflow-hidden lg:min-h-[70vh]">
    <div class="absolute inset-0">
      <img
        src={CoursesBG.src}
        alt="OLLI course catalog"
        class="h-full w-full object-cover blur-sm scale-110"
      />
      <div class="absolute inset-0 bg-gradient-to-t from-[#02275A]/90 via-[#02275A]/70 to-[#02275A]/45"></div>
      <div class="pointer-events-none absolute -top-32 left-1/2 -translate-x-1/2 h-[500px] w-[800px] max-w-full opacity-[0.2]" style="background: radial-gradient(ellipse 50% 50% at center, #004ADD 0%, transparent 70%);"></div>
    </div>

    <div class="relative z-10 mx-auto w-full max-w-4xl px-4 pb-16 pt-24 text-center sm:px-6 lg:px-8">
      <div class="max-w-4xl mx-auto">
        <p class="text-sm uppercase tracking-[0.35em] text-blue-200 font-semibold mb-4">Course Catalog</p>
        <h1 class="text-4xl sm:text-5xl lg:text-6xl font-extrabold font-display text-white leading-tight tracking-[-0.02em]" style="text-shadow: 0 1px 2px rgba(0,0,0,0.4), 0 0 1px rgba(255,255,255,0.1);">
          Welcome to OLLI HU
        </h1>
        <p class="mt-6 text-lg text-white/80 max-w-3xl mx-auto leading-relaxed">
          We're thrilled to have you here! At OLLI, we believe that learning never stops. Whether you're exploring a new passion, diving deeper into a lifelong interest, or simply looking to connect with a vibrant community of fellow learners, you've come to the right place.
        </p>
        <p class="mt-4 text-lg text-white/80 max-w-3xl mx-auto leading-relaxed">
          Our courses are designed to engage, inspire, and empower—no tests, no grades, just the joy of learning for learning's sake. From history and science to art, literature, and wellness, there's something here for everyone.
        </p>
      </div>
    </div>

    <!-- Curved bottom separator -->
    <div class="absolute bottom-0 left-0 right-0 z-10 h-16">
      <svg class="h-full w-full" viewBox="0 0 1440 64" preserveAspectRatio="none" fill="#FFFFFF">
        <path d="M0 64 Q360 0 720 32 Q1080 64 1440 16 L1440 64 Z" />
      </svg>
    </div>
  </section>

  <section class="bg-white py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid gap-10 lg:grid-cols-[1.2fr_1fr] items-center">
        <div class="rounded-xl border border-slate-200 bg-white p-4 shadow-sm transition hover:-translate-y-0.5 hover:shadow-md sm:p-6">
          <img
            src={catalogImages[0]}
            alt="OLLI Course Catalog cover"
            class="mx-auto h-auto w-full max-h-[480px] rounded-2xl object-contain"
            loading="lazy"
          />
          <div class="mt-5 text-center">
            <button id="open-catalog-btn" class="inline-flex cursor-pointer items-center justify-center rounded-full bg-[#004ADD] px-6 py-3 text-base font-semibold text-white shadow-sm transition hover:bg-[#02275A] hover:shadow-lg hover:-translate-y-0.5">
              Click here to view the course catalog
            </button>
          </div>
        </div>

        <div class="rounded-xl border border-slate-200 bg-white p-8 shadow-sm transition hover:-translate-y-0.5 hover:shadow-md sm:p-10">
          <h2 class="text-3xl font-extrabold font-display text-[#02275A]">Ready to discover your next adventure?</h2>
          <p class="mt-4 text-lg leading-relaxed text-slate-700">
            Browse our courses, meet our incredible instructors, and join a community where curiosity knows no age limit.
          </p>
          <div class="mt-8 flex flex-wrap gap-4">
            <a href="mailto:alisha.beverley@hamptonu.edu" class="inline-flex items-center justify-center rounded-full bg-[#004ADD] px-6 py-3 text-base font-semibold text-white shadow-sm transition hover:bg-[#02275A] hover:shadow-lg hover:-translate-y-0.5">
              Email Alisha
            </a>
            <a href="tel:7577275434" class="inline-flex items-center justify-center rounded-full border border-slate-200 px-6 py-3 text-base font-semibold text-slate-700 shadow-sm transition hover:bg-slate-50 hover:shadow-md hover:-translate-y-0.5">
              Call 757-727-5434
            </a>
          </div>
          <p class="mt-6 text-base leading-relaxed text-slate-600">
            For questions or assistance, please call <strong class="text-[#02275A]">757-727-5434</strong> or email <strong class="text-[#02275A]">Alisha Beverley</strong> at <a href="mailto:alisha.beverley@hamptonu.edu" class="font-semibold text-[#004ADD] underline decoration-1 underline-offset-2 hover:text-[#02275A] transition">alisha.beverley@hamptonu.edu</a>.
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="bg-[#F8FAFC] py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="text-3xl font-extrabold font-display text-[#02275A]">Current Courses</h2>
        <p class="mt-4 text-lg text-slate-700">Engaging, accessible, and member-led learning experiences designed for adults 50 and better.</p>
      </div>

      <h3 class="mt-12 mb-4 text-xl font-bold font-display text-[#02275A]">Fitness &amp; Dance</h3>
      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        <div class="rounded-xl border border-slate-200 bg-white p-6 shadow-sm transition hover:-translate-y-0.5 hover:shadow-md">
          <p class="text-sm font-semibold uppercase tracking-[0.2em] text-[#004ADD] mb-3">Fitness</p>
          <h3 class="text-xl font-bold font-display text-[#02275A]">Move Your Body: Fitness</h3>
          <p class="mt-3 text-base leading-relaxed text-slate-700">
            An energetic weightlifting and strength-training class where participants learn to move more freely while gaining strength and flexibility through weights, resistance bands, and varied exercises.
          </p>
        </div>
        <div class="rounded-xl border border-slate-200 bg-white p-6 shadow-sm transition hover:-translate-y-0.5 hover:shadow-md">
          <p class="text-sm font-semibold uppercase tracking-[0.2em] text-[#004ADD] mb-3">Dance</p>
          <h3 class="text-xl font-bold font-display text-[#02275A]">Line Dancing for Everyone (Beginners)</h3>
          <p class="mt-3 text-base leading-relaxed text-slate-700">
            Learn basic steps and simple dances that promote fun, fitness, confidence, mental stimulation, and social connection.
          </p>
        </div>

        <div class="rounded-xl border border-slate-200 bg-white p-6 shadow-sm transition hover:-translate-y-0.5 hover:shadow-md">
          <p class="text-sm font-semibold uppercase tracking-[0.2em] text-[#004ADD] mb-3">Dance</p>
          <h3 class="text-xl font-bold font-display text-[#02275A]">Line Dancing for Everyone (Returning Steppers)</h3>
          <p class="mt-3 text-base leading-relaxed text-slate-700">
            A more advanced line dancing class that challenges memory, coordination, and confidence through multi-step routines while encouraging movement and fun.
          </p>
        </div>

        <div class="rounded-xl border border-slate-200 bg-white p-6 shadow-sm transition hover:-translate-y-0.5 hover:shadow-md">
          <p class="text-sm font-semibold uppercase tracking-[0.2em] text-[#004ADD] mb-3">Dance &amp; Fitness</p>
          <h3 class="text-xl font-bold font-display text-[#02275A]">Salsa-Cise</h3>
          <p class="mt-3 text-base leading-relaxed text-slate-700">
            A dance fitness class that uses Latin rhythms and movement to lift the spirit, reduce stress, and promote physical and mental well-being. No prior experience is required.
          </p>
        </div>

        <div class="rounded-xl border border-slate-200 bg-white p-6 shadow-sm transition hover:-translate-y-0.5 hover:shadow-md">
          <p class="text-sm font-semibold uppercase tracking-[0.2em] text-[#004ADD] mb-3">Fitness</p>
          <h3 class="text-xl font-bold font-display text-[#02275A]">Zumba</h3>
          <p class="mt-3 text-base leading-relaxed text-slate-700">
            A popular exercise program that combines Latin music with choreographed dance movements to create an engaging aerobic workout.
          </p>
        </div>
      </div>

      <h3 class="mt-12 mb-4 text-xl font-bold font-display text-[#02275A]">Arts &amp; Crafts</h3>
      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        <div class="rounded-xl border border-slate-200 bg-white p-6 shadow-sm transition hover:-translate-y-0.5 hover:shadow-md">
          <p class="text-sm font-semibold uppercase tracking-[0.2em] text-[#004ADD] mb-3">Arts &amp; Crafts</p>
          <h3 class="text-xl font-bold font-display text-[#02275A]">Handmade Greeting Cards</h3>
          <p class="mt-3 text-base leading-relaxed text-slate-700">
            Learn how to create unique handmade greeting cards using different card-making tools and techniques that family and friends will treasure.
          </p>
        </div>
      </div>

      <h3 class="mt-12 mb-4 text-xl font-bold font-display text-[#02275A]">Languages</h3>
      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        <div class="rounded-xl border border-slate-200 bg-white p-6 shadow-sm transition hover:-translate-y-0.5 hover:shadow-md">
          <p class="text-sm font-semibold uppercase tracking-[0.2em] text-[#004ADD] mb-3">Language</p>
          <h3 class="text-xl font-bold font-display text-[#02275A]">Intermediate Spanish</h3>
          <p class="mt-3 text-base leading-relaxed text-slate-700">
            Designed for members with a basic background in Spanish pronunciation, grammar, and vocabulary who want to continue developing their Spanish skills. <em>In person &amp; virtual.</em>
          </p>
        </div>

        <div class="rounded-xl border border-slate-200 bg-white p-6 shadow-sm transition hover:-translate-y-0.5 hover:shadow-md">
          <p class="text-sm font-semibold uppercase tracking-[0.2em] text-[#004ADD] mb-3">Language</p>
          <h3 class="text-xl font-bold font-display text-[#02275A]">Beginning Spanish</h3>
          <p class="mt-3 text-base leading-relaxed text-slate-700">
            Designed for members who want to begin learning how to speak Spanish fluently. <em>In person &amp; virtual.</em>
          </p>
        </div>
      </div>

      <h3 class="mt-12 mb-4 text-xl font-bold font-display text-[#02275A]">Wellness</h3>
      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        <div class="rounded-xl border border-slate-200 bg-white p-6 shadow-sm transition hover:-translate-y-0.5 hover:shadow-md">
          <p class="text-sm font-semibold uppercase tracking-[0.2em] text-[#004ADD] mb-3">Wellness</p>
          <h3 class="text-xl font-bold font-display text-[#02275A]">Yoga For Everyone</h3>
          <p class="mt-3 text-base leading-relaxed text-slate-700">
            A yoga class focused on uniting body, breath, and mind through mindful movement, relaxation, and meditation to support healthy aging and wellness.
          </p>
        </div>
      </div>

      <h3 class="mt-12 mb-4 text-xl font-bold font-display text-[#02275A]">Book Club &amp; Discussion</h3>
      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        <div class="rounded-xl border border-slate-200 bg-white p-6 shadow-sm transition hover:-translate-y-0.5 hover:shadow-md">
          <p class="text-sm font-semibold uppercase tracking-[0.2em] text-[#004ADD] mb-3">Book Club</p>
          <h3 class="text-xl font-bold font-display text-[#02275A]">Kings Roundtable Osher Book Club</h3>
          <p class="mt-3 text-base leading-relaxed text-slate-700">
            An interest group centered around reading, discussion, and sharing a love of storytelling.
          </p>
        </div>

        <div class="rounded-xl border border-slate-200 bg-white p-6 shadow-sm transition hover:-translate-y-0.5 hover:shadow-md">
          <p class="text-sm font-semibold uppercase tracking-[0.2em] text-[#004ADD] mb-3">Discussion</p>
          <h3 class="text-xl font-bold font-display text-[#02275A]">Knowledge More Abundantly</h3>
          <p class="mt-3 text-base leading-relaxed text-slate-700">
            Explores the nature of knowledge, truth, and misinformation through guided discussions and debates about sources of knowledge, personal biases, and distinguishing fact from myth.
          </p>
        </div>
      </div>
    </div>
  </section>

  <dialog id="catalog-modal" class="fixed inset-0 z-[100] h-full max-h-none w-full max-w-none bg-black/70 p-4 backdrop:bg-black/70 open:flex open:items-center open:justify-center">
    <div class="relative w-full max-w-5xl rounded-2xl bg-white p-2 shadow-2xl sm:p-4">
      <button onclick="document.getElementById('catalog-modal').close()" class="absolute -right-3 -top-3 z-10 flex h-9 w-9 items-center justify-center rounded-full bg-[#02275A] text-white shadow-lg transition hover:bg-[#004ADD]" aria-label="Close catalog">
        <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12" />
        </svg>
      </button>

      <div class="swiper [--swiper-navigation-size:24px]" id="catalog-swiper">
        <div class="swiper-wrapper">
          {catalogImages.map((img, idx) => (
            <div class="swiper-slide !flex items-center justify-center {isCover(idx) ? 'cover-slide' : ''}">
              <div class="flex w-full items-center justify-center {isCover(idx) ? 'max-w-[80%]' : ''}">
                <div class="relative flex-1 {!isCover(idx) && isLastInLeftPair(idx) ? 'pr-1 md:pr-2' : ''} {!isCover(idx) && isFirstInRightPair(idx) ? 'pl-1 md:pl-2' : ''}">
                  {!isCover(idx) && isLastInLeftPair(idx) && <div class="pointer-events-none absolute inset-y-0 right-0 w-3 bg-gradient-to-l from-black/5 to-transparent z-10" />}
                  {!isCover(idx) && isFirstInRightPair(idx) && <div class="pointer-events-none absolute inset-y-0 left-0 w-2 bg-gradient-to-r from-black/5 to-transparent z-10" />}
                  <img
                    src={img}
                    alt={`OLLI Course Catalog page $${idx + 1}`}
                    class="h-auto max-h-[75vh] w-full object-contain drop-shadow-[1px_0_4px_rgba(0,0,0,0.12)]"
                    style="background: linear-gradient(135deg, #fefefe 0%, #f8f6f0 100%);"
                    loading="lazy"
                  />
                </div>
              </div>
            </div>
          ))}
        </div>
        <div class="swiper-pagination !relative !mt-3"></div>
        <div class="swiper-button-prev !text-[#004ADD]"></div>
        <div class="swiper-button-next !text-[#004ADD]"></div>
      </div>
    </div>
  </dialog>

  <style>
    #catalog-swiper {
      perspective: 1600px;
    }
    #catalog-swiper .swiper-slide {
      transition: transform 0.5s cubic-bezier(0.22, 0.61, 0.36, 1), opacity 0.4s ease;
    }
    #catalog-swiper.md\:two-up {
      perspective: 1600px;
    }
    #catalog-swiper.md\:two-up .swiper-slide-prev {
      opacity: 0.4;
      transform: perspective(1600px) rotateY(18deg) scale(0.92);
      transform-origin: right center;
    }
    #catalog-swiper.md\:two-up .swiper-slide-next {
      opacity: 0.4;
      transform: perspective(1600px) rotateY(-18deg) scale(0.92);
      transform-origin: left center;
    }
    #catalog-swiper.md\:two-up .swiper-slide-active {
      opacity: 1;
      transform: perspective(1600px) rotateY(0deg) scale(1);
    }
    #catalog-swiper:not(.md\:two-up) .swiper-slide {
      opacity: 1 !important;
      transform: none !important;
    }
    #catalog-swiper:not(.md\:two-up) .swiper-slide img {
      max-height: 85vh;
    }
    #catalog-swiper.md\:two-up .cover-slide > div {
      max-width: none !important;
    }
  </style>

  <script>
    import Swiper from 'swiper';
    import { Navigation, Pagination, Keyboard } from 'swiper/modules';
    import 'swiper/css';
    import 'swiper/css/navigation';
    import 'swiper/css/pagination';

    let swiperInstance = null;

    document.getElementById('open-catalog-btn')?.addEventListener('click', function () {
      const modal = document.getElementById('catalog-modal');
      modal.showModal();

      if (!swiperInstance) {
        const el = document.getElementById('catalog-swiper');
        if (el) {
          const isDesktop = () => window.innerWidth >= 768;

          swiperInstance = new Swiper(el, {
            modules: [Navigation, Pagination, Keyboard],
            slidesPerView: 1,
            slidesPerGroup: 1,
            spaceBetween: 0,
            navigation: { nextEl: '.swiper-button-next', prevEl: '.swiper-button-prev' },
            pagination: { el: '.swiper-pagination', clickable: true },
            keyboard: { enabled: true },
            grabCursor: true,
            breakpoints: {
              768: {
                slidesPerView: 2,
                slidesPerGroup: 2,
                spaceBetween: 0,
              },
            },
            on: {
              init: function () {
                this.el.classList.toggle('md\\:two-up', isDesktop());
              },
              resize: function () {
                this.el.classList.toggle('md\\:two-up', isDesktop());
              },
            },
          });
        }
      } else {
        swiperInstance.update();
      }
    });
  </script>
</Layout>
