---
import Layout from '../layouts/Layout.astro';
import TravelBG from '../images/TravelBG.png';
import act1 from '../images/CourseCatalog/9.png';
import act2 from '../images/CourseCatalog/11.png';
import act3 from '../images/CourseCatalog/12.png';
import act4 from '../images/CourseCatalog/13.png';
import trip1 from '../images/Trip1.png';
import trip2 from '../images/Trip2.png';
import trip3 from '../images/Trip3.png';
import trip4 from '../images/Trip4.png';
import trip5 from '../images/Trip5.png';
import trip6 from '../images/Trip6.png';
import v1 from '../images/Vendor1.png';
import v2 from '../images/Vendor2.png';
import v3 from '../images/Vendor3.png';
import v4 from '../images/Vendor4.png';
import v5 from '../images/Vendor5.png';

const gallery = [act1, act2, act3, act4];
const trips = [trip1, trip2, trip3, trip4, trip5, trip6];
const vendors = [v1, v2, v3, v4, v5];
---

<Layout>
  <!-- ====== Hero ====== -->
  <section class="relative flex min-h-[60vh] items-center overflow-hidden lg:min-h-[70vh]">
    <div class="absolute inset-0">
      <img
        src={TravelBG.src}
        alt="OLLI travel and activities"
        class="h-full w-full object-cover blur-sm scale-110"
      />
      <div class="absolute inset-0 bg-gradient-to-t from-[#02275A]/90 via-[#02275A]/70 to-[#02275A]/45"></div>
      <div class="pointer-events-none absolute -top-32 left-1/2 -translate-x-1/2 h-[500px] w-[800px] max-w-full opacity-[0.2]" style="background: radial-gradient(ellipse 50% 50% at center, #004ADD 0%, transparent 70%);"></div>
    </div>

    <div class="relative z-10 mx-auto w-full max-w-4xl px-4 pb-16 pt-24 text-center sm:px-6 lg:px-8">
      <div class="max-w-4xl mx-auto">
        <h1 class="text-4xl sm:text-5xl lg:text-6xl font-extrabold font-display text-white leading-tight tracking-[-0.02em]" style="text-shadow: 0 1px 2px rgba(0,0,0,0.4), 0 0 1px rgba(255,255,255,0.1);">
          Activities &amp; Travel
        </h1>
        <p class="mt-6 text-lg text-white/80 max-w-3xl mx-auto leading-relaxed">
          Discover meaningful experiences beyond the classroom with OLLI at Hampton University. Our activities and travel opportunities bring members together through exploration, connection, and shared interests. From local adventures and cultural experiences to special events and unforgettable journeys, OLLI provides opportunities to stay engaged, build friendships, and continue learning in exciting new ways.
        </p>
      </div>
    </div>

    <!-- Curved bottom separator -->
    <div class="absolute bottom-0 left-0 right-0 z-10 h-16">
      <svg class="h-full w-full" viewBox="0 0 1440 64" preserveAspectRatio="none" fill="#FFFFFF">
        <path d="M0 64 Q360 0 720 32 Q1080 64 1440 16 L1440 64 Z" />
      </svg>
    </div>
  </section>

  <section class="bg-white py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-4xl mx-auto">
        <h2 class="text-3xl font-extrabold font-display text-[#02275A]">Activities</h2>
        <div class="mt-6 space-y-5 text-lg leading-relaxed text-slate-700">
          <p>
            Experience the joy of lifelong learning with OLLI at Hampton University through a wide variety of engaging activities designed to inspire curiosity, creativity, and connection. From educational programs and social gatherings to hands-on experiences and community events, our activities provide opportunities to explore interests, meet new people, and enjoy meaningful experiences with fellow members.
          </p>
          <p>
            Whether your interests include arts, history, wellness, technology, culture, or simply spending time with a vibrant community of learners, OLLI activities offer a welcoming environment where members can discover new passions and continue growing at every stage of life.
          </p>
        </div>
      </div>

      <div class="mt-12">
        <div class="swiper" id="activities-gallery">
          <div class="swiper-wrapper">
            {gallery.map((img, i) => (
              <div class="swiper-slide cursor-pointer overflow-hidden rounded-2xl border border-slate-200 bg-[#F8FAFC] shadow-sm transition hover:-translate-y-0.5 hover:shadow-md" onclick={`openLightbox(${i})`}>
                <img src={img.src} alt={`Activity photo ${i + 1}`} class="h-auto w-full max-h-[400px] object-contain" loading="lazy" />
              </div>
            ))}
          </div>
          <div class="swiper-scrollbar !relative !mt-3"></div>
        </div>
      </div>
    </div>
  </section>

  <section class="bg-[#F8FAFC] py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-4xl mx-auto">
        <h2 class="text-3xl font-extrabold font-display text-[#02275A]">Upcoming Trips</h2>
        <div class="mt-6 space-y-5 text-lg leading-relaxed text-slate-700">
          <p>
            OLLI travel opportunities extend the learning experience beyond the classroom, allowing members to explore new places, cultures, and perspectives while building connections with fellow travelers. These journeys complement the conversations and discoveries that begin in our courses, lectures, and special interest groups.
          </p>
          <p>
            From international destinations such as Italy, Costa Rica, London, and Paris to local explorations throughout Hampton Roads and beyond, OLLI trips offer enriching experiences that combine learning, adventure, and fellowship.
          </p>
          <p>
            Future travel opportunities will include a variety of experiences, from longer immersive journeys within the United States and abroad to shorter excursions designed to highlight local history, culture, and attractions.
          </p>
        </div>
      </div>

      <div class="mt-12">
        <div class="hidden sm:grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
          {trips.map((img, i) => (
            <div class="cursor-pointer overflow-hidden rounded-2xl border border-slate-200 bg-[#F8FAFC] shadow-sm transition hover:-translate-y-0.5 hover:shadow-md" onclick={`openTripLightbox(${i})`}>
              <img src={img.src} alt={`Trip photo ${i + 1}`} class="aspect-[3/4] w-full object-cover" loading="lazy" />
            </div>
          ))}
        </div>
        <div class="swiper sm:!hidden" id="trips-gallery">
          <div class="swiper-wrapper">
            {trips.map((img, i) => (
              <div class="swiper-slide cursor-pointer overflow-hidden rounded-2xl border border-slate-200 bg-[#F8FAFC] shadow-sm transition hover:-translate-y-0.5 hover:shadow-md" onclick={`openTripLightbox(${i})`}>
                <img src={img.src} alt={`Trip photo ${i + 1}`} class="aspect-[3/4] w-full object-cover" loading="lazy" />
              </div>
            ))}
          </div>
          <div class="swiper-scrollbar !relative !mt-3"></div>
        </div>
      </div>
    </div>
  </section>

  <section class="bg-white py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-4xl mx-auto">
        <h2 class="text-3xl font-extrabold font-display text-[#02275A]">Event Vendors</h2>
        <div class="mt-6 space-y-5 text-lg leading-relaxed text-slate-700">
          <p>
            Our event vendors help bring OLLI experiences to life by providing quality services, resources, and memorable experiences for our members and community events. From specialty offerings and local partnerships to event support and unique experiences, our vendors contribute to creating engaging and enjoyable gatherings.
          </p>
          <p>
            We value the relationships we build with trusted partners who share our commitment to providing exceptional experiences for the OLLI community.
          </p>
        </div>
      </div>

      <div class="mt-12">
        <div class="hidden sm:grid gap-4 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-5">
          {vendors.map((img) => (
            <div class="overflow-hidden rounded-2xl border border-slate-200 bg-[#F8FAFC] shadow-sm transition hover:-translate-y-0.5 hover:shadow-md">
              <img src={img.src} alt="Event vendor" class="aspect-square w-full object-cover" loading="lazy" />
            </div>
          ))}
        </div>
        <div class="swiper sm:!hidden" id="vendors-gallery">
          <div class="swiper-wrapper">
            {vendors.map((img) => (
              <div class="swiper-slide overflow-hidden rounded-2xl border border-slate-200 bg-[#F8FAFC] shadow-sm transition hover:-translate-y-0.5 hover:shadow-md">
                <img src={img.src} alt="Event vendor" class="aspect-square w-full object-cover" loading="lazy" />
              </div>
            ))}
          </div>
          <div class="swiper-scrollbar !relative !mt-3"></div>
        </div>
      </div>
    </div>
  </section>

  <dialog id="gallery-lightbox" class="fixed inset-0 z-[100] h-full max-h-none w-full max-w-none bg-black/80 p-4 backdrop:bg-black/80 open:flex open:items-center open:justify-center">
    <div class="relative w-full max-w-5xl">
      <button onclick="document.getElementById('gallery-lightbox').close()" class="absolute -right-2 -top-10 z-10 flex h-9 w-9 items-center justify-center rounded-full bg-white/20 text-white backdrop-blur transition hover:bg-white/40" aria-label="Close">
        <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12" />
        </svg>
      </button>
      <div class="swiper !w-full" id="lightbox-swiper">
        <div class="swiper-wrapper">
          {gallery.map((img) => (
            <div class="swiper-slide !flex items-center justify-center !w-full !flex-shrink-0">
              <img src={img.src} alt="Activity photo" class="h-auto max-h-[80vh] w-full rounded-xl object-contain" loading="lazy" />
            </div>
          ))}
        </div>
        <div class="swiper-button-prev lb-prev !text-white"></div>
        <div class="swiper-button-next lb-next !text-white"></div>
      </div>
    </div>
  </dialog>

  <dialog id="trips-lightbox" class="fixed inset-0 z-[100] h-full max-h-none w-full max-w-none bg-black/80 p-4 backdrop:bg-black/80 open:flex open:items-center open:justify-center">
    <div class="relative w-full max-w-5xl">
      <button onclick="document.getElementById('trips-lightbox').close()" class="absolute -right-2 -top-10 z-10 flex h-9 w-9 items-center justify-center rounded-full bg-white/20 text-white backdrop-blur transition hover:bg-white/40" aria-label="Close">
        <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12" />
        </svg>
      </button>
      <div class="swiper !w-full" id="trips-lightbox-swiper">
        <div class="swiper-wrapper">
          {trips.map((img) => (
            <div class="swiper-slide !flex items-center justify-center !w-full !flex-shrink-0">
              <img src={img.src} alt="Trip photo" class="h-auto max-h-[80vh] w-full rounded-xl object-contain" loading="lazy" />
            </div>
          ))}
        </div>
        <div class="swiper-button-prev trip-lb-prev !text-white"></div>
        <div class="swiper-button-next trip-lb-next !text-white"></div>
      </div>
    </div>
  </dialog>

  <script>
    import Swiper from 'swiper';
    import { Scrollbar, Navigation, Keyboard } from 'swiper/modules';
    import 'swiper/css';
    import 'swiper/css/scrollbar';
    import 'swiper/css/navigation';

    function initSwipers() {
      const activitiesEl = document.getElementById('activities-gallery');
      if (activitiesEl && !activitiesEl.swiper) {
        new Swiper(activitiesEl, {
          modules: [Scrollbar, Keyboard],
          slidesPerView: 1.2,
          spaceBetween: 12,
          scrollbar: { el: '.swiper-scrollbar', draggable: true },
          keyboard: { enabled: true },
          grabCursor: true,
          breakpoints: {
            640: { slidesPerView: 2.2, spaceBetween: 16 },
            1024: { slidesPerView: 4, spaceBetween: 16 },
          },
        });
      }

      const tripsEl = document.getElementById('trips-gallery');
      if (tripsEl && !tripsEl.swiper && window.getComputedStyle(tripsEl).display !== 'none') {
        new Swiper(tripsEl, {
          modules: [Scrollbar, Keyboard],
          slidesPerView: 1.3,
          spaceBetween: 12,
          scrollbar: { el: '.swiper-scrollbar', draggable: true },
          keyboard: { enabled: true },
          grabCursor: true,
        });
      }

      const vendorsEl = document.getElementById('vendors-gallery');
      if (vendorsEl && !vendorsEl.swiper && window.getComputedStyle(vendorsEl).display !== 'none') {
        new Swiper(vendorsEl, {
          modules: [Scrollbar, Keyboard],
          slidesPerView: 1.3,
          spaceBetween: 12,
          scrollbar: { el: '.swiper-scrollbar', draggable: true },
          keyboard: { enabled: true },
          grabCursor: true,
        });
      }
    }

    document.addEventListener('astro:page-load', initSwipers);
    initSwipers();

    let lbSwiper = null;
    window.openLightbox = (index) => {
      const modal = document.getElementById('gallery-lightbox');
      modal.showModal();
      setTimeout(() => {
        if (lbSwiper && lbSwiper.el?.isConnected) {
          lbSwiper.slideTo(index);
        } else {
          lbSwiper = new Swiper(document.getElementById('lightbox-swiper'), {
            modules: [Navigation, Keyboard],
            slidesPerView: 1,
            navigation: { nextEl: '.lb-next', prevEl: '.lb-prev' },
            keyboard: { enabled: true },
            grabCursor: true,
            initialSlide: index,
          });
        }
      }, 150);
    };

    let tripLbSwiper = null;
    window.openTripLightbox = (index) => {
      const modal = document.getElementById('trips-lightbox');
      modal.showModal();
      setTimeout(() => {
        if (tripLbSwiper && tripLbSwiper.el?.isConnected) {
          tripLbSwiper.slideTo(index);
        } else {
          tripLbSwiper = new Swiper(document.getElementById('trips-lightbox-swiper'), {
            modules: [Navigation, Keyboard],
            slidesPerView: 1,
            navigation: { nextEl: '.trip-lb-next', prevEl: '.trip-lb-prev' },
            keyboard: { enabled: true },
            grabCursor: true,
            initialSlide: index,
          });
        }
      }, 150);
    };
  </script>
</Layout>
