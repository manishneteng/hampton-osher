---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import ClientRouter from 'astro/components/ClientRouter.astro';
import OsherLogo from '../images/Osher20Logo.png';
---

<!DOCTYPE html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Osher Lifelong Learning Institute</title>
    <link rel="icon" type="image/png" href={OsherLogo.src} />
    <ClientRouter />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400..900;1,400..900&display=swap" rel="stylesheet" />
    <style>
      @media (prefers-reduced-motion: no-preference) {
        html::view-transition-old(root) {
          animation: 350ms ease-out both fade-out;
        }
        html::view-transition-new(root) {
          animation: 500ms ease-out 120ms both fade-in;
        }
      }
      @keyframes fade-out {
        to { opacity: 0; }
      }
      @keyframes fade-in {
        from { opacity: 0; }
      }
    </style>
  </head>
  <body class="bg-[#F3F8FC] text-[#353A3C] font-sans antialiased flex flex-col min-h-screen">
    
    <Header />
    
    {/* flex-grow ensures the footer is pushed to the bottom if the page is short */}
    <main class="flex-grow">
      <slot />
    </main>
    
    <Footer />
    
  </body>
</html>